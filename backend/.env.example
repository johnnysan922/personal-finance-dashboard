# Copy to `.env` locally (never commit `.env`).
# Market data provider: `yahoo` (v1), later `alpaca` or `polygon`.
MARKET_DATA_PROVIDER=yahoo

# SQLite by default; use PostgreSQL URL in production if needed.
DATABASE_URL=sqlite:///./portfolio.db

# Comma-separated browser origins for CORS (dev + prod).
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Comma-separated symbols for the WebSocket price poller.
PRICE_STREAM_SYMBOLS=AAPL,MSFT,GOOG
